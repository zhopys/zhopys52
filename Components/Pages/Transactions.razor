@page "/transactions"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using MiniFinance.Data
@using MiniFinance.Services
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject ApplicationDbContext DbContext
@inject UserManager<ApplicationUser> UserManager
@inject ICategorizationService CategorizationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS
@attribute [Authorize]

<PageTitle>Транзакции - MiniFinance</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="page-header">
            <div class="title">
                <h1>Транзакции</h1>
                <div class="meta text-muted">Управление операциями и быстрый ввод</div>
            </div>
            <div class="page-actions">
                <button class="btn btn-outline" @onclick="ToggleQuickEntry">⚡ Быстрый ввод</button>
                <a class="btn btn-primary" href="/transactions/new">+ Новая</a>
            </div>
        </div>

        @if (showMessage)
        {
            <div class="alert alert-success" role="status" aria-live="polite">@message</div>
        }

        @if (showQuickEntry)
        {
            <div class="card mb-3">
                <div class="card-header">Быстрый ввод</div>
                <div class="card-body">
                    <div class="row" style="gap:.5rem">
                        <button class="btn btn-outline-danger" @onclick='() => QuickAddExpense("Аренда офиса", 1500, "Аренда")'>🏢 Аренда — 1500₽</button>
                        <button class="btn btn-outline-danger" @onclick='() => QuickAddExpense("Интернет и связь", 850, "Связь")'>📡 Связь — 850₽</button>
                        <button class="btn btn-outline-success" @onclick='() => QuickAddIncome("Оплата от клиента", 10000, "Продажи")'>💰 Продажа — 10000₽</button>
                        <button class="btn btn-outline" @onclick="ToggleQuickEntry">Закрыть</button>
                    </div>
                </div>
            </div>
        }

        <div class="card mb-3">
            <div class="card-header">Добавить транзакцию</div>
            <div class="card-body">
                <EditForm Model="@newTransaction" OnValidSubmit="@AddTransaction">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger" />

                    <div class="row" style="gap:.5rem;align-items:end">
                        <div style="min-width:160px">
                            <label class="label">Дата</label>
                            <InputDate id="date" class="input" @bind-Value="newTransaction.Date" />
                        </div>
                        <div style="min-width:140px">
                            <label class="label">Сумма</label>
                            <InputNumber id="amount" class="input" @bind-Value="newTransaction.Amount" @bind-Value:after="OnAmountChanged" />
                            <div class="small text-muted">- для расхода</div>
                        </div>
                        <div style="flex:1">
                            <label class="label">Описание</label>
                            <InputText id="description" class="input" @bind-Value="newTransaction.Description" @bind-Value:after="OnDescriptionChanged" />
                        </div>
                        <div style="min-width:180px">
                            <label class="label">Категория</label>
                            <input id="category" list="categoryList" class="input" @bind="newTransaction.Category" aria-label="Категория" placeholder="Выберите или введите категорию" />
                            <datalist id="categoryList">
                                @foreach (var c in GetUniqueCategories()) { <option value="@c"></option> }
                            </datalist>
                            @if (!string.IsNullOrEmpty(suggestedCategory)) { <div class="small text-muted">💡 Рекомендация: @suggestedCategory</div> }
                        </div>
                    </div>

                    <div style="margin-top:1rem;display:flex;gap:.5rem">
                        <button type="submit" class="btn btn-primary">Добавить</button>
                        <button type="button" class="btn btn-outline" @onclick="ClearForm">Очистить</button>
                    </div>
                </EditForm>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <div class="row" style="gap:.5rem;align-items:center">
                        <div style="flex:1;min-width:220px">
                        <input type="text" class="input" placeholder="Поиск по описанию..." @bind="searchQuery" @bind:event="oninput" aria-label="Поиск по описанию" />
                    </div>
                    <div style="min-width:180px">
                        <select class="input" @bind="filterCategory">
                            <option value="">Все категории</option>
                            @foreach (var cat in GetUniqueCategories()) { <option value="@cat">@cat</option> }
                        </select>
                    </div>
                    <div style="min-width:120px">
                        <select class="input" @bind="filterType">
                            <option value="all">Все</option>
                            <option value="income">Доходы</option>
                            <option value="expense">Расходы</option>
                        </select>
                    </div>
                    <div style="min-width:140px">
                        <button class="btn btn-outline" @onclick="ClearFilters">Сбросить</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Список транзакций <span class="text-muted">— Всего: @GetFilteredTransactions().Count()</span></div>
            <div class="card-body">
                @if (transactions == null)
                {
                    <div class="center py-4">Загрузка...</div>
                }
                else if (!transactions.Any())
                {
                    <div class="empty-state">Нет транзакций. Добавьте первую операцию.</div>
                }
                else
                {
                    var filtered = GetFilteredTransactions().ToList();
                    @if (!filtered.Any())
                    {
                        <div class="alert">Нет транзакций, соответствующих фильтрам.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Дата</th>
                                        <th>Описание</th>
                                        <th>Категория</th>
                                        <th class="text-end">Сумма</th>
                                        <th class="text-center">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in filtered)
                                    {
                                        <tr>
                                            <td><div class="muted">@t.Date.ToString("dd.MM.yyyy")</div></td>
                                            <td>
                                                @if (editingId == t.Id)
                                                {
                                                    <input type="text" class="input" @bind="editDescription" />
                                                }
                                                else { @t.Description }
                                            </td>
                                            <td>
                                                @if (editingId == t.Id)
                                                {
                                                    <input type="text" class="input" @bind="editCategory" />
                                                }
                                                else { <span class="badge">@t.Category</span> }
                                            </td>
                                            <td class="text-end">
                                                @if (editingId == t.Id)
                                                {
                                                    <input type="number" step="0.01" class="input" @bind="editAmount" style="width:120px" />
                                                }
                                                else
                                                {
                                                    <span class="fw-bold @(t.Amount >= 0 ? "text-success" : "text-danger")">@(t.Amount >= 0 ? "+" : "")@t.Amount.ToString("N2") ₽</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (editingId == t.Id)
                                                {
                                                    <button class="btn btn-sm btn-primary" @onclick="() => SaveEdit(t.Id)" title="Сохранить изменения">Сохранить</button>
                                                    <button class="btn btn-sm btn-outline" @onclick="CancelEdit" title="Отменить редактирование">Отмена</button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-outline" @onclick="() => StartEdit(t)" title="Редактировать транзакцию">Редактировать</button>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDeleteTransaction(t.Id)" title="Удалить транзакцию">Удалить</button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="3" class="text-end fw-bold">Итого:</td>
                                        <td class="text-end fw-bold"> <span class="@(filtered.Sum(t => t.Amount) >= 0 ? "text-success" : "text-danger")">@filtered.Sum(t => t.Amount).ToString("N2") ₽</span></td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    </Authorized>
</AuthorizeView>

@code {
    private List<Transaction> transactions = new();

    private Transaction newTransaction { get; set; } = new() { Date = DateTime.Today };

    private string suggestedCategory = string.Empty;
    private bool showQuickEntry = false;
    private bool showMessage = false;
    private string message = string.Empty;

    // Фильтры
    private string searchQuery = string.Empty;
    private string filterCategory = string.Empty;
    private string filterType = "all";

    // Редактирование
    private int? editingId = null;
    private string editDescription = string.Empty;
    private string editCategory = string.Empty;
    private decimal editAmount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user != null)
        {
            transactions = await DbContext.Transactions
                .Where(t => t.UserId == user.Id)
                .OrderByDescending(t => t.Date)
                .ToListAsync();
        }
    }

    private void OnDescriptionChanged()
    {
        if (!string.IsNullOrWhiteSpace(newTransaction.Description) && newTransaction.Amount != 0)
        {
            suggestedCategory = CategorizationService.CategorizeTransaction(
                newTransaction.Description,
                newTransaction.Amount);

            if (string.IsNullOrWhiteSpace(newTransaction.Category))
            {
                newTransaction.Category = suggestedCategory;
            }
        }
    }

    private void OnAmountChanged()
    {
        OnDescriptionChanged();
    }

    private async Task AddTransaction()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user != null)
        {
            if (string.IsNullOrWhiteSpace(newTransaction.Category))
            {
                newTransaction.Category = CategorizationService.CategorizeTransaction(
                    newTransaction.Description,
                    newTransaction.Amount);
            }

            newTransaction.UserId = user.Id;
            DbContext.Transactions.Add(newTransaction);
            await DbContext.SaveChangesAsync();

            await ShowMessageAsync($"✅ Транзакция добавлена: {newTransaction.Description}");

            newTransaction = new Transaction { Date = DateTime.Today };
            suggestedCategory = string.Empty;
            await LoadTransactions();
        }
    }

    private async Task QuickAddExpense(string description, decimal amount, string category)
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user != null)
        {
            var transaction = new Transaction
            {
                Date = DateTime.Today,
                Amount = -amount,
                Description = description,
                Category = category,
                UserId = user.Id
            };

            DbContext.Transactions.Add(transaction);
            await DbContext.SaveChangesAsync();

            await ShowMessageAsync($"✅ Расход добавлен: {description} (-{amount}₽)");
            await LoadTransactions();
        }
    }

    private async Task QuickAddIncome(string description, decimal amount, string category)
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user != null)
        {
            var transaction = new Transaction
            {
                Date = DateTime.Today,
                Amount = amount,
                Description = description,
                Category = category,
                UserId = user.Id
            };

            DbContext.Transactions.Add(transaction);
            await DbContext.SaveChangesAsync();

            await ShowMessageAsync($"✅ Доход добавлен: {description} (+{amount}₽)");
            await LoadTransactions();
        }
    }

    private void StartEdit(Transaction t)
    {
        editingId = t.Id;
        editDescription = t.Description;
        editCategory = t.Category;
        editAmount = t.Amount;
    }

    private async Task SaveEdit(int id)
    {
        var transaction = await DbContext.Transactions.FindAsync(id);
        if (transaction != null)
        {
            transaction.Description = editDescription;
            transaction.Category = editCategory;
            transaction.Amount = editAmount;

            await DbContext.SaveChangesAsync();
            await ShowMessageAsync("✅ Транзакция обновлена");

            editingId = null;
            await LoadTransactions();
        }
    }

    private void CancelEdit()
    {
        editingId = null;
    }

    private async Task DeleteTransaction(int id)
    {
        var transaction = await DbContext.Transactions.FindAsync(id);
        if (transaction != null)
        {
            DbContext.Transactions.Remove(transaction);
            await DbContext.SaveChangesAsync();

            await ShowMessageAsync("🗑️ Транзакция удалена");
            await LoadTransactions();
        }
    }

    private void ToggleQuickEntry()
    {
        showQuickEntry = !showQuickEntry;
    }

    private void ClearForm()
    {
        newTransaction = new Transaction { Date = DateTime.Today };
        suggestedCategory = string.Empty;
    }

    private void ShowMessage(string msg)
    {
        message = msg;
        showMessage = true;
    }

    private async Task ShowMessageAsync(string msg, int autoHideMs = 4000)
    {
        message = msg;
        showMessage = true;
        StateHasChanged();
        try
        {
            await Task.Delay(autoHideMs);
        }
        catch { }
        showMessage = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmDeleteTransaction(int id)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", "Удалить транзакцию? Это действие нельзя отменить.");
        if (!ok) return;
        await DeleteTransaction(id);
    }

    private IEnumerable<Transaction> GetFilteredTransactions()
    {
        if (transactions == null) return Enumerable.Empty<Transaction>();

        var filtered = transactions.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            filtered = filtered.Where(t => t.Description.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(filterCategory))
        {
            filtered = filtered.Where(t => t.Category == filterCategory);
        }

        if (filterType == "income")
        {
            filtered = filtered.Where(t => t.Amount > 0);
        }
        else if (filterType == "expense")
        {
            filtered = filtered.Where(t => t.Amount < 0);
        }

        return filtered.OrderByDescending(t => t.Date);
    }

    private List<string> GetUniqueCategories()
    {
        return transactions?.Select(t => t.Category).Distinct().OrderBy(c => c).ToList() ?? new List<string>();
    }

    private void ClearFilters()
    {
        searchQuery = string.Empty;
        filterCategory = string.Empty;
        filterType = "all";
    }
}

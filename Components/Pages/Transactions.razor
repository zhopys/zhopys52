@page "/transactions"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using MiniFinance.Data
@using MiniFinance.Services
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject ApplicationDbContext DbContext
@inject UserManager<ApplicationUser> UserManager
@inject ICategorizationService CategorizationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@attribute [Authorize]

<PageTitle>Транзакции - MiniFinance</PageTitle>

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1>💳 Транзакции</h1>
            <button class="btn btn-primary" @onclick="ToggleQuickEntry">
                <span class="bi bi-lightning-fill"></span> Быстрый ввод
            </button>
        </div>

        @if (showMessage)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @message
                <button type="button" class="btn-close" @onclick="() => showMessage = false"></button>
            </div>
        }

        <!-- Быстрый ввод расходов -->
        @if (showQuickEntry)
        {
            <div class="card mb-3 border-primary">
                <div class="card-header bg-primary text-white">
                    <h5>⚡ Быстрый ввод расхода</h5>
                </div>
                <div class="card-body">
                    <div class="row g-2 mb-3">
                        <div class="col-md-3">
                            <button class="btn btn-outline-danger w-100" @onclick='() => QuickAddExpense("Аренда офиса", 1500, "Аренда")'>
                                🏢 Аренда<br/><small>1500₽</small>
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-outline-danger w-100" @onclick='() => QuickAddExpense("Интернет и связь", 850, "Связь")'>
                                📡 Связь<br/><small>850₽</small>
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-outline-danger w-100" @onclick='() => QuickAddExpense("Бензин", 1200, "Транспорт")'>
                                ⛽ Бензин<br/><small>1200₽</small>
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-outline-danger w-100" @onclick='() => QuickAddExpense("Канцелярия", 500, "Офис")'>
                                📝 Канцелярия<br/><small>500₽</small>
                            </button>
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-3">
                            <button class="btn btn-outline-danger w-100" @onclick='() => QuickAddExpense("Реклама", 3000, "Реклама")'>
                                📢 Реклама<br/><small>3000₽</small>
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-outline-danger w-100" @onclick='() => QuickAddExpense("Комиссия банка", 200, "Банк")'>
                                🏦 Банк<br/><small>200₽</small>
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-outline-success w-100" @onclick='() => QuickAddIncome("Оплата от клиента", 10000, "Продажи")'>
                                💰 Продажа<br/><small>10000₽</small>
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-outline-success w-100" @onclick='() => QuickAddIncome("Оказание услуг", 5000, "Услуги")'>
                                🛠️ Услуга<br/><small>5000₽</small>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Форма добавления новой транзакции -->
        <div class="card mb-3">
            <div class="card-header">
                <h5>➕ Добавить транзакцию</h5>
            </div>
            <div class="card-body">
                <EditForm Model="@newTransaction" OnValidSubmit="@AddTransaction">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger" />

                    <div class="row g-3">
                        <div class="col-md-2">
                            <label for="date" class="form-label">Дата:</label>
                            <InputDate id="date" class="form-control" @bind-Value="newTransaction.Date" />
                        </div>
                        <div class="col-md-2">
                            <label for="amount" class="form-label">Сумма:</label>
                            <InputNumber id="amount" class="form-control" @bind-Value="newTransaction.Amount"
                                         @bind-Value:after="OnAmountChanged" placeholder="0.00" />
                            <small class="text-muted">- для расхода</small>
                        </div>
                        <div class="col-md-5">
                            <label for="description" class="form-label">Описание:</label>
                            <InputText id="description" class="form-control" @bind-Value="newTransaction.Description"
                                       @bind-Value:after="OnDescriptionChanged" placeholder="Описание транзакции" />
                        </div>
                        <div class="col-md-3">
                            <label for="category" class="form-label">Категория:</label>
                            <InputText id="category" class="form-control" @bind-Value="newTransaction.Category"
                                       placeholder="Автоопределение" />
                            @if (!string.IsNullOrEmpty(suggestedCategory))
                            {
                                <small class="text-primary">💡 @suggestedCategory</small>
                            }
                        </div>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary">
                            <span class="bi bi-plus-circle"></span> Добавить транзакцию
                        </button>
                        <button type="button" class="btn btn-secondary ms-2" @onclick="ClearForm">
                            <span class="bi bi-x-circle"></span> Очистить
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>

        <!-- Фильтры и поиск -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <input type="text" class="form-control" placeholder="🔍 Поиск по описанию..."
                               @bind="searchQuery" @bind:event="oninput" />
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" @bind="filterCategory">
                            <option value="">Все категории</option>
                            @foreach (var cat in GetUniqueCategories())
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select class="form-select" @bind="filterType">
                            <option value="all">Все</option>
                            <option value="income">Доходы</option>
                            <option value="expense">Расходы</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">
                            <span class="bi bi-x"></span> Сбросить фильтры
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Таблица транзакций -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5>📋 Список транзакций</h5>
                <span class="badge bg-primary">Всего: @GetFilteredTransactions().Count()</span>
            </div>
            <div class="card-body">
                @if (transactions == null)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Загрузка...</span>
                        </div>
                    </div>
                }
                else if (!transactions.Any())
                {
                    <div class="alert alert-info">
                        <h5>📭 Нет транзакций</h5>
                        <p>Добавьте первую транзакцию используя форму выше или быстрый ввод.</p>
                    </div>
                }
                else
                {
                    var filtered = GetFilteredTransactions().ToList();

                    @if (!filtered.Any())
                    {
                        <div class="alert alert-warning">
                            Нет транзакций, соответствующих фильтрам.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Дата</th>
                                        <th>Описание</th>
                                        <th>Категория</th>
                                        <th class="text-end">Сумма</th>
                                        <th class="text-center">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in filtered)
                                    {
                                        <tr>
                                            <td>
                                                <span class="text-muted">@t.Date.ToString("dd.MM.yyyy")</span>
                                            </td>
                                            <td>
                                                @if (editingId == t.Id)
                                                {
                                                    <input type="text" class="form-control form-control-sm"
                                                           @bind="editDescription" />
                                                }
                                                else
                                                {
                                                    @t.Description
                                                }
                                            </td>
                                            <td>
                                                @if (editingId == t.Id)
                                                {
                                                    <input type="text" class="form-control form-control-sm"
                                                           @bind="editCategory" />
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@t.Category</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                @if (editingId == t.Id)
                                                {
                                                    <input type="number" step="0.01" class="form-control form-control-sm"
                                                           @bind="editAmount" style="width: 120px; display: inline-block;" />
                                                }
                                                else
                                                {
                                                    <span class="@(t.Amount >= 0 ? "text-success" : "text-danger") fw-bold">
                                                        @(t.Amount >= 0 ? "+" : "")@t.Amount.ToString("N2") ₽
                                                    </span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (editingId == t.Id)
                                                {
                                                    <button class="btn btn-sm btn-success me-1" @onclick="() => SaveEdit(t.Id)">
                                                        <span class="bi bi-check"></span>
                                                    </button>
                                                    <button class="btn btn-sm btn-secondary" @onclick="CancelEdit">
                                                        <span class="bi bi-x"></span>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartEdit(t)">
                                                        <span class="bi bi-pencil"></span>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTransaction(t.Id)">
                                                        <span class="bi bi-trash"></span>
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <td colspan="3" class="text-end fw-bold">Итого:</td>
                                        <td class="text-end fw-bold">
                                            <span class="@(filtered.Sum(t => t.Amount) >= 0 ? "text-success" : "text-danger")">
                                                @filtered.Sum(t => t.Amount).ToString("N2") ₽
                                            </span>
                                        </td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    </Authorized>
</AuthorizeView>

@code {
    private List<Transaction> transactions = new();

    private Transaction newTransaction { get; set; } = new() { Date = DateTime.Today };

    private string suggestedCategory = string.Empty;
    private bool showQuickEntry = false;
    private bool showMessage = false;
    private string message = string.Empty;

    // Фильтры
    private string searchQuery = string.Empty;
    private string filterCategory = string.Empty;
    private string filterType = "all";

    // Редактирование
    private int? editingId = null;
    private string editDescription = string.Empty;
    private string editCategory = string.Empty;
    private decimal editAmount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user != null)
        {
            transactions = await DbContext.Transactions
                .Where(t => t.UserId == user.Id)
                .OrderByDescending(t => t.Date)
                .ToListAsync();
        }
    }

    private void OnDescriptionChanged()
    {
        if (!string.IsNullOrWhiteSpace(newTransaction.Description) && newTransaction.Amount != 0)
        {
            suggestedCategory = CategorizationService.CategorizeTransaction(
                newTransaction.Description,
                newTransaction.Amount);

            if (string.IsNullOrWhiteSpace(newTransaction.Category))
            {
                newTransaction.Category = suggestedCategory;
            }
        }
    }

    private void OnAmountChanged()
    {
        OnDescriptionChanged();
    }

    private async Task AddTransaction()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user != null)
        {
            if (string.IsNullOrWhiteSpace(newTransaction.Category))
            {
                newTransaction.Category = CategorizationService.CategorizeTransaction(
                    newTransaction.Description,
                    newTransaction.Amount);
            }

            newTransaction.UserId = user.Id;
            DbContext.Transactions.Add(newTransaction);
            await DbContext.SaveChangesAsync();

            ShowMessage($"✅ Транзакция добавлена: {newTransaction.Description}");

            newTransaction = new Transaction { Date = DateTime.Today };
            suggestedCategory = string.Empty;
            await LoadTransactions();
        }
    }

    private async Task QuickAddExpense(string description, decimal amount, string category)
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user != null)
        {
            var transaction = new Transaction
            {
                Date = DateTime.Today,
                Amount = -amount,
                Description = description,
                Category = category,
                UserId = user.Id
            };

            DbContext.Transactions.Add(transaction);
            await DbContext.SaveChangesAsync();

            ShowMessage($"✅ Расход добавлен: {description} (-{amount}₽)");
            await LoadTransactions();
        }
    }

    private async Task QuickAddIncome(string description, decimal amount, string category)
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user != null)
        {
            var transaction = new Transaction
            {
                Date = DateTime.Today,
                Amount = amount,
                Description = description,
                Category = category,
                UserId = user.Id
            };

            DbContext.Transactions.Add(transaction);
            await DbContext.SaveChangesAsync();

            ShowMessage($"✅ Доход добавлен: {description} (+{amount}₽)");
            await LoadTransactions();
        }
    }

    private void StartEdit(Transaction t)
    {
        editingId = t.Id;
        editDescription = t.Description;
        editCategory = t.Category;
        editAmount = t.Amount;
    }

    private async Task SaveEdit(int id)
    {
        var transaction = await DbContext.Transactions.FindAsync(id);
        if (transaction != null)
        {
            transaction.Description = editDescription;
            transaction.Category = editCategory;
            transaction.Amount = editAmount;

            await DbContext.SaveChangesAsync();
            ShowMessage("✅ Транзакция обновлена");

            editingId = null;
            await LoadTransactions();
        }
    }

    private void CancelEdit()
    {
        editingId = null;
    }

    private async Task DeleteTransaction(int id)
    {
        var transaction = await DbContext.Transactions.FindAsync(id);
        if (transaction != null)
        {
            DbContext.Transactions.Remove(transaction);
            await DbContext.SaveChangesAsync();

            ShowMessage("🗑️ Транзакция удалена");
            await LoadTransactions();
        }
    }

    private void ToggleQuickEntry()
    {
        showQuickEntry = !showQuickEntry;
    }

    private void ClearForm()
    {
        newTransaction = new Transaction { Date = DateTime.Today };
        suggestedCategory = string.Empty;
    }

    private void ShowMessage(string msg)
    {
        message = msg;
        showMessage = true;
    }

    private IEnumerable<Transaction> GetFilteredTransactions()
    {
        if (transactions == null) return Enumerable.Empty<Transaction>();

        var filtered = transactions.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            filtered = filtered.Where(t => t.Description.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(filterCategory))
        {
            filtered = filtered.Where(t => t.Category == filterCategory);
        }

        if (filterType == "income")
        {
            filtered = filtered.Where(t => t.Amount > 0);
        }
        else if (filterType == "expense")
        {
            filtered = filtered.Where(t => t.Amount < 0);
        }

        return filtered.OrderByDescending(t => t.Date);
    }

    private List<string> GetUniqueCategories()
    {
        return transactions?.Select(t => t.Category).Distinct().OrderBy(c => c).ToList() ?? new List<string>();
    }

    private void ClearFilters()
    {
        searchQuery = string.Empty;
        filterCategory = string.Empty;
        filterType = "all";
    }
}

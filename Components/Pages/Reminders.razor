@page "/reminders"
@rendermode InteractiveServer
@using MiniFinance.Data.Models
@using Microsoft.EntityFrameworkCore
@using MiniFinance.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@inject ApplicationDbContext DbContext
@inject IJSRuntime JS
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@attribute [Authorize]

<PageTitle>Напоминания - MiniFinance</PageTitle>

<div class="page-header">
    <div class="title">
        <h1>Напоминания</h1>
        <div class="meta text-muted">Управление напоминаниями о платежах</div>
    </div>
    <div class="page-actions">
        <button class="btn btn-primary" @onclick="() => showCreateForm = true">+ Создать напоминание</button>
        <button class="btn btn-outline" @onclick="LoadReminders">⟳ Обновить</button>
    </div>
</div>

@if (showMessage)
{
    <div class="alert alert-success">@message</div>
}
@if (showError)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="card mb-3">
    <div class="card-body">
        <ul class="nav nav-tabs" role="tablist" style="gap:.5rem">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab=="active"?"active":"")" role="tab" @onclick='() => SetTab("active")' title="Показывать напоминания, которые ещё не оплачены">Активные</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab=="paid"?"active":"")" role="tab" @onclick='() => SetTab("paid")' title="Показывать уже оплаченные напоминания">Оплаченные</button>
            </li>
        </ul>
        <div class="small text-muted" style="margin-top:.5rem">Используйте вкладки для переключения между активными и оплаченными напоминаниями.</div>
    </div>
</div>

@if (showCreateForm)
{
    <div class="card mb-3">
        <div class="card-header">@(editId==0?"Создать напоминание":"Редактировать напоминание")</div>
        <div class="card-body">
            <div class="row" style="gap:.5rem;align-items:end">
                <div style="flex:2">
                    <label class="label">Название</label>
                    <input class="input" @bind="newName" placeholder="Например: Оплата аренды" aria-label="Название напоминания" />
                </div>
                <div style="min-width:160px">
                    <label class="label">Сумма</label>
                    <input type="number" step="0.01" class="input" @bind="newAmount" placeholder="0.00" aria-label="Сумма" />
                </div>
                <div style="min-width:220px">
                    <label class="label">Категория</label>
                    <select class="input" @bind="newCategory">
                        <option value="">(без категории)</option>
                        @foreach(var c in categories) { <option value="@c">@c</option> }
                    </select>
                </div>
                <div style="min-width:180px">
                    <label class="label">Периодичность</label>
                    <select class="input" @bind="newFrequency">
                        <option value="OneTime">Разово</option>
                        <option value="Monthly">Ежемесячно</option>
                        <option value="Yearly">Ежегодно</option>
                    </select>
                </div>
                <div style="min-width:180px">
                    <label class="label">Дата</label>
                    <InputDate class="input" @bind-Value="newDate" />
                </div>
            </div>
            <div style="margin-top:1rem;display:flex;gap:.5rem">
                <button class="btn btn-primary" @onclick="SaveReminder" title="Сохранить напоминание">@(editId==0?"Создать напоминание":"Сохранить напоминание")</button>
                <button class="btn btn-outline" @onclick="CancelForm" title="Отменить">Отмена</button>
            </div>
        </div>
    </div>
}

<div class="card">
    <div class="card-header">Список напоминаний</div>
    <div class="card-body">
        @if (reminders==null)
        {
            <div class="center py-4">Загрузка...</div>
        }
        else if (!reminders.Any(r => activeTab=="active" ? !r.IsPaid : r.IsPaid))
        {
            <div class="empty-state">Нет напоминаний в этой вкладке.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Название</th>
                            <th>Сумма</th>
                            <th>Категория</th>
                            <th>Дата платежа</th>
                            <th>Периодичность</th>
                            <th>Статус</th>
                            <th class="text-center">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var r in reminders.Where(r => activeTab=="active" ? !r.IsPaid : r.IsPaid).OrderBy(r => r.Date))
                        {
                            <tr>
                                <td>@r.Name</td>
                                <td class="text-end">@r.Amount.ToString("N2") ₽</td>
                                <td>@r.Category</td>
                                <td>@r.Date.ToString("dd.MM.yyyy")</td>
                                <td>@(r.Frequency==ReminderFrequency.OneTime?"Разово": r.Frequency==ReminderFrequency.Monthly?"Ежемесячно":"Ежегодно")</td>
                                <td>@(r.IsPaid? $"Оплачено {r.PaidDate?.ToString("dd.MM.yyyy")}" : "Ожидает")</td>
                                <td class="text-center">
                                    @if (!r.IsPaid)
                                    {
                                        <button class="btn btn-sm btn-success" @onclick="() => MarkPaid(r.Id)" title="Отметить как оплачено">Отметить как оплачено</button>
                                    }
                                    <button class="btn btn-sm btn-outline" @onclick="() => EditReminder(r)" title="Редактировать напоминание">Редактировать</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(r.Id)" title="Удалить напоминание">Удалить</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<Reminder>? reminders;
    private List<string> categories = new();

    private bool showCreateForm = false;
    private bool showMessage = false;
    private string message = string.Empty;
    private bool showError = false;
    private string errorMessage = string.Empty;

    private string activeTab = "active";

    // form
    private int editId = 0;
    private string newName = string.Empty;
    private decimal newAmount = 0;
    private string newCategory = string.Empty;
    private ReminderFrequency newFrequency = ReminderFrequency.OneTime;
    private DateTime newDate = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
        await LoadReminders();
    }

    private async Task LoadCategories()
    {
        categories = await DbContext.Categories.OrderBy(c => c.Name).Select(c => c.Name).ToListAsync();
    }

    private async Task LoadReminders()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user == null) return;

        reminders = await DbContext.Reminders
            .Where(r => r.UserId == user.Id)
            .ToListAsync();
    }

    private void SetTab(string t)
    {
        activeTab = t;
    }

    private void CancelForm()
    {
        editId = 0;
        newName = string.Empty;
        newAmount = 0;
        newCategory = string.Empty;
        newFrequency = ReminderFrequency.OneTime;
        newDate = DateTime.Today;
        showCreateForm = false;
        showError = false;
    }

    private async Task SaveReminder()
    {
        if (string.IsNullOrWhiteSpace(newName))
        {
            errorMessage = "Введите название";
            showError = true;
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user == null) return;

        if (editId == 0)
        {
            var r = new Reminder
            {
                Name = newName.Trim(),
                Amount = newAmount,
                Category = newCategory,
                Frequency = newFrequency,
                Date = newDate,
                UserId = user.Id,
                IsPaid = false
            };
            DbContext.Reminders.Add(r);
            message = "✅ Напоминание создано";
        }
        else
        {
            var r = await DbContext.Reminders.FindAsync(editId);
            if (r == null) return;
            r.Name = newName.Trim();
            r.Amount = newAmount;
            r.Category = newCategory;
            r.Frequency = newFrequency;
            r.Date = newDate;
            message = "✅ Напоминание обновлено";
        }

        await DbContext.SaveChangesAsync();
        showMessage = true;
        CancelForm();
        await LoadReminders();
    }

    private void EditReminder(Reminder r)
    {
        editId = r.Id;
        newName = r.Name;
        newAmount = r.Amount;
        newCategory = r.Category;
        newFrequency = r.Frequency;
        newDate = r.Date;
        showCreateForm = true;
    }

    private async Task ConfirmDelete(int id)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", "Удалить напоминание? Это действие нельзя отменить.");
        if (!ok) return;
        await DeleteReminder(id);
    }

    private async Task DeleteReminder(int id)
    {
        var r = await DbContext.Reminders.FindAsync(id);
        if (r == null) return;
        DbContext.Reminders.Remove(r);
        await DbContext.SaveChangesAsync();
        message = "✅ Напоминание удалено";
        showMessage = true;
        await LoadReminders();
    }

    private async Task MarkPaid(int id)
    {
        var r = await DbContext.Reminders.FindAsync(id);
        if (r == null) return;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user == null) return;

        // create expense transaction
        var tx = new Transaction
        {
            Date = r.Date,
            Amount = -Math.Abs(r.Amount),
            Description = $"Оплата: {r.Name}",
            Category = r.Category ?? string.Empty,
            UserId = user.Id,
            ProjectId = null
        };

        DbContext.Transactions.Add(tx);

        if (r.Frequency == ReminderFrequency.OneTime)
        {
            r.IsPaid = true;
            r.PaidDate = DateTime.Now;
        }
        else if (r.Frequency == ReminderFrequency.Monthly)
        {
            // advance to next month
            r.Date = r.Date.AddMonths(1);
        }
        else if (r.Frequency == ReminderFrequency.Yearly)
        {
            r.Date = r.Date.AddYears(1);
        }

        await DbContext.SaveChangesAsync();
        message = "✅ Отмечено как оплачено и создана транзакция";
        showMessage = true;
        await LoadReminders();
    }
}

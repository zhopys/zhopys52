<nav class="nav-scrollable">
    <ul class="nav" role="navigation" aria-label="Main navigation">
        <AuthorizeView>
            <Authorized>
                <li class="nav-item user-info" style="padding:.6rem .75rem;border-bottom:1px solid var(--border)">
                    <div class="small text-muted">Пользователь</div>
                    <div class="" style="font-weight:700">@context.User.Identity?.Name</div>
                    @if (context.User.Identity?.IsAuthenticated == true)
                    {
                        <div class="small text-muted">@context.User.FindFirst("email")?.Value</div>
                    }
                </li>

                <li class="nav-item">
                    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span>
                        <span>Главная</span>
                    </NavLink>
                </li>

                <li class="nav-item">
                    <NavLink class="nav-link" href="/transactions" title="Перейти к списку транзакций">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span>
                        <span>Транзакции</span>
                    </NavLink>
                </li>

                <li class="nav-item nav-section" style="margin-top:.5rem;padding-top:.5rem;border-top:1px dashed var(--border)">
                    <div class="small text-muted" style="padding:.25rem .75rem">Управление</div>
                </li>

                <li class="nav-item">
                    <NavLink class="nav-link" href="/manage-projects" title="Проекты и отделы">
                        <span class="bi bi-briefcase-nav-menu" aria-hidden="true"></span>
                        <span>Проекты</span>
                    </NavLink>
                </li>

                <li class="nav-item">
                    <NavLink class="nav-link" href="/reminders" title="Напоминания о платежах и счетах">
                        <span class="bi bi-bell-fill-nav-menu" aria-hidden="true"></span>
                        <span>Напоминания</span>
                    </NavLink>
                </li>

                <li class="nav-item">
                    <NavLink class="nav-link" href="/reports">
                        <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span>
                        <span>Отчёты</span>
                    </NavLink>
                </li>

                <li class="nav-item">
                    <NavLink class="nav-link" href="/insights">
                        <span class="bi bi-lightning-charge-fill-nav-menu" aria-hidden="true"></span>
                        <span>Аналитика роста</span>
                    </NavLink>
                </li>

                <li class="nav-item">
                    <NavLink class="nav-link" href="/import">
                        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span>
                        <span>Импорт CSV</span>
                    </NavLink>
                </li>

                <li class="nav-item nav-section" style="margin-top:.6rem;padding-top:.6rem;border-top:1px solid var(--border)">
                    <NavLink class="nav-link" href="/account">
                        <span class="bi bi-person-circle-nav-menu" aria-hidden="true"></span>
                        <span>Профиль</span>
                    </NavLink>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-danger" href="/logout">
                        <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span>
                        <span>Выйти</span>
                    </a>
                </li>
            </Authorized>
            <NotAuthorized>
                <li class="nav-item">
                    <NavLink class="nav-link" href="/account/login">
                        <span class="bi bi-person-nav-menu" aria-hidden="true"></span>
                        <span>Войти</span>
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="/account/register">
                        <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span>
                        <span>Регистрация</span>
                    </NavLink>
                </li>
            </NotAuthorized>
        </AuthorizeView>
    </ul>
</nav>

@code {
    private bool collapseNavMenu = false; // sidebar is visible by default in wide layout
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}